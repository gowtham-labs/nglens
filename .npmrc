# Dependency Security Configuration

# Audit level: only fail on high/critical vulnerabilities
audit-level=high

# Prefer offline mode (use cache)
prefer-offline=true

# Disable update notifier (privacy)
update-notifier=false

# Only allow https registry
https-proxy=null
proxy=null

# Engine strict mode (enforce Node/npm versions)
engine-strict=true

# Save exact versions (no ^ or ~)
save-exact=true

# No package-lock auto-update
package-lock=true

# Strict peer dependencies
legacy-peer-deps=false
