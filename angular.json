{
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "panel": {
      "projectType": "application",
      "root": "src/devtools/panel",
      "sourceRoot": "src/devtools/panel",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/panel",
            "index": "src/devtools/panel/index.html",
            "browser": "src/devtools/panel/main.ts",
            "polyfills": [],
            "tsConfig": "src/devtools/panel/tsconfig.app.json",
            "styles": [
              "src/devtools/panel/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                }
              ],
              "outputHashing": "none",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                }
              }
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  }
}
