{
  "version": 1,
  "cli": {
    "cache": {
      "enabled": false
    },
    "analytics": "b0894c2e-ae66-49ac-9809-0a4f4388b0b9",
    "schematicCollections": [
      "angular-eslint"
    ]
  },
  "newProjectRoot": "projects",
  "projects": {
    "panel": {
      "projectType": "application",
      "root": "src/devtools/panel",
      "sourceRoot": "src/devtools/panel",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/panel",
            "index": "src/devtools/panel/index.html",
            "browser": "src/devtools/panel/main.ts",
            "polyfills": [],
            "tsConfig": "src/devtools/panel/tsconfig.app.json",
            "styles": [
              "src/devtools/panel/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                }
              ],
              "outputHashing": "none",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                }
              }
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/devtools/panel/**/*.ts",
              "src/devtools/panel/**/*.html"
            ],
            "eslintConfig": "src/devtools/panel/eslint.config.js"
          }
        }
      }
    }
  }
}
