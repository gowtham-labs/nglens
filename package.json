{
  "name": "nglens",
  "version": "1.0.2",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:panel && npm run build:extension",
    "build:panel": "ng build --configuration production --output-path dist/panel",
    "build:extension": "vite build",
    "dev:panel": "ng build --watch --configuration development",
    "dev:extension": "vite build --watch",
    "test": "vitest --run"
  },
  "dependencies": {
    "@angular/animations": "~22.0.2",
    "@angular/cdk": "~22.0.2",
    "@angular/common": "~22.0.2",
    "@angular/compiler": "~22.0.2",
    "@angular/core": "~22.0.2",
    "@angular/platform-browser": "~22.0.2",
    "@angular/router": "~22.0.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.6.3",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "~22.0.3",
    "@angular/cli": "~22.0.3",
    "@angular/compiler-cli": "~22.0.2",
    "@types/chrome": "^0.1.42",
    "autoprefixer": "^10.4.20",
    "fast-check": "4.8.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vitest": "4.1.9"
  },
  "overrides": {
    "piscina": "5.2.0"
  }
}
